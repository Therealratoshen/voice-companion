# Environment Variables
# Copy to .env.local and fill in your values

# ── Groq ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenClaw (agentic tasks) ──────────────────────────────────────────────
# If set, task-oriented messages are routed to OpenClaw instead of Groq.
# Leave empty to use Groq for everything (fine for demo).
OPENCLAW_API_URL=http://localhost:8080
OPENCLAW_API_KEY=your_openclaw_api_key_here

# ── TiDB (memory) ───────────────────────────────────────────────────────────
# Sign up free at tidbcloud.com → create serverless cluster
TIDB_HOST=your_host.hr.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your_username
TIDB_PASSWORD=your_password
TIDB_DATABASE=voice_companion

# ── Next.js ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3456

# ─────────────────────────────────────────────────────────────────────────
# TTS: Edge TTS (no API key needed — uses Microsoft Neural voices)
# Install: pip install edge-tts
#
# MiniMax TTS/STT available in lib/minimax.ts as optional alternative:
# Sign up: platform.minimaxi.com
# MINIMAX_API_KEY=your_key
# MINIMAX_GROUP_ID=your_group_id
# MINIMAX_VOICE_ID=male-qn-qingse
# ─────────────────────────────────────────────────────────────────────────
