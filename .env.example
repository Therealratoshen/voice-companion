# ============================================================
# Voice Companion — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# ── Agora Conversational AI ──────────────────────────────────
# Get from: https://console.agora.io/ → Conversational AI → Project Settings
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here

# ── MiniMax — LLM (Text Generation) + TTS (Speech) ─────────
# Get from: https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# MiniMax LLM — model name from MiniMax platform
MINIMAX_LLM_MODEL=abab6.5s-chat

# MiniMax TTS — voice ID (see available voices in MiniMax dashboard)
# Indonesian female: try "female_brazilian_portuguese_1" or your registered voice
# See: https://platform.minimaxi.com/document/Voice
MINIMAX_VOICE_ID=female_tianmei

# MiniMax API base URL (use CN endpoint for Chinese-hosted accounts)
MINIMAX_API_BASE_URL=https://api.minimax.chat
MINIMAX_TTS_URL=https://api.minimax.io/v1/t2a_v2

# ── Rafiqspace STT (Optional — used for transcript logging) ──
# The Agora SDK uses Deepgram for STT by default.
# Rafiqspace can be used for higher-quality Indonesian transcription
# when not using the Agora voice pipeline.
# Get token from: https://api.rafiqspace.ai/
RAFIQ_API_KEY=your_rafiqspace_api_key_here
RAFIQ_BASE_URL=https://api.rafiqspace.ai/api/v1

# ── TiDB — Conversation Memory (MySQL-compatible serverless) ─
# Get from: https://tidbcloud.com/ → Connection → Standard Connection
TIDB_HOST=your_tidb_host.hr.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your_tidb_username
TIDB_PASSWORD=your_tidb_password
TIDB_DATABASE=voice_companion

# ── Next.js ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3456
