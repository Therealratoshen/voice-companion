# Environment Variables
# Copy this file to .env.local and fill in your values

# Groq — LLM (Llama) + STT (Whisper)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# MiniMax — TTS (Text-to-Speech)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
MINIMAX_VOICE_ID=male-qn-qingse

# TiDB — Conversation Memory (MySQL-compatible serverless)
TIDB_HOST=your_tidb_host.hr.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your_tidb_username
TIDB_PASSWORD=your_tidb_password
TIDB_DATABASE=voice_companion

# Next.js
NODE_ENV=development
PORT=3456
