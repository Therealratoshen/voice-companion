# Environment Variables
# Copy this file to .env.local and fill in your values

# Groq — LLM (Llama) + STT (Whisper)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# TiDB — Conversation Memory (MySQL-compatible serverless)
TIDB_HOST=your_tidb_host.hr.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your_tidb_username
TIDB_PASSWORD=your_tidb_password
TIDB_DATABASE=voice_companion

# Next.js
NODE_ENV=development
PORT=3456

# ─────────────────────────────────────────────────
# Note: TTS uses Edge TTS (Microsoft Neural voices)
# Install with: pip install edge-tts
# No API key needed for Edge TTS.
#
# MiniMax is available in lib/minimax.ts as optional:
# MiniMax API key → platform.minimaxi.com
# MINIMAX_API_KEY=your_key
# MINIMAX_GROUP_ID=your_group_id
# MINIMAX_VOICE_ID=male-qn-qingse
# ─────────────────────────────────────────────────
