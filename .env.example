# ============================================================
# Voice Companion — Environment Variables
# Copy to .env.local (dev) or .env.production (prod)
# ============================================================

# ── Agora Conversational AI ──────────────────────────────────
# Required for Agora SDK mode (Deepgram STT + MiniMax LLM + MiniMax TTS)
# Get from: https://console.agora.io/ → Conversational AI → Projects
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here
# Optional: restrict to region — US | EU | AP | CN (default: US)
# AGORA_AREA=US

# ── MiniMax — LLM + TTS (both modes) ──────────────────────
# Get from: https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here

# MiniMax LLM — model name from MiniMax platform
MINIMAX_LLM_MODEL=abab6.5s-chat

# MiniMax TTS — voice ID (see dashboard at platform.minimaxi.com/document/Voice)
# Good Indonesian voices: female_tianmei, male-qn-qingse
MINIMAX_VOICE_ID=female_tianmei

MINIMAX_API_BASE_URL=https://api.minimax.chat
MINIMAX_TTS_URL=https://api.minimax.io/v1/t2a_v2

# ── Rafiqspace STT (legacy mode: when AGORA_APP_ID is NOT set) ──
# Get from: https://api.rafiqspace.ai/ → API Keys
# This is the STT provider for the legacy WebSocket pipeline.
# Not needed when using Agora mode (which uses Deepgram).
RAFIQ_API_KEY=your_rafiqspace_api_key_here
RAFIQ_BASE_URL=https://api.rafiqspace.ai/api/v1

# ── TiDB — Conversation Memory ───────────────────────────────
# Optional but recommended — enables memory/context across sessions
# Get from: https://tidbcloud.com/ → Serverless → Connect → Standard
TIDB_HOST=your_tidb_host.hr.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your_tidb_username
TIDB_PASSWORD=your_tidb_password
TIDB_DATABASE=voice_companion

# ── Next.js ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3456
